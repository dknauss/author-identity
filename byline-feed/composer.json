{
	"name": "dknauss/byline-feed",
	"description": "Enriches RSS, Atom, and JSON feeds with structured author identity metadata using the Byline extension vocabulary.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"yoast/phpunit-polyfills": "^2.0",
		"wp-coding-standards/wpcs": "^3.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0"
	},
	"scripts": {
		"test": "phpunit --configuration=phpunit.xml.dist",
		"lint": "phpcs --standard=WordPress --extensions=php --ignore=vendor,node_modules,build,dist,tests .",
		"lint:fix": "phpcbf --standard=WordPress --extensions=php --ignore=vendor,node_modules,build,dist,tests ."
	},
	"config": {
		"platform": {
			"php": "7.4.0"
		},
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
